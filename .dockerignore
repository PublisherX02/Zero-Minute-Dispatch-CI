# Python cache & compiled bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Git & CI
.git/
.github/
.gitignore
.gitattributes

# Tests (not needed in runtime images)
tests/

# IDE / editor configs
.claude/
.vscode/
.idea/
*.code-workspace

# OS artefacts
.DS_Store
Thumbs.db

# Local env overrides (real keys are injected via docker-compose env_file)
*.env
.env.local
.env.*.local

# Docs & media
README.md
NOTES.md
*.mp3
*.mp4
*.log
*.txt
apicode.txt

# Temp files
tempCodeRunnerFile.py
check_model.py

# Docker files themselves (no need to copy into image)
# NOTE: docker-entrypoint.sh is intentionally NOT excluded — it is copied into the backend image
Dockerfile*
docker-compose*.yml
.dockerignore
